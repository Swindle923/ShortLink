{
  "info": {
    "name": "ShortLink Functional Suite",
    "_postman_id": "5f0917a6-e2b9-43d2-b4d8-2ef9ab0f6f20",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "短链接系统功能测试集合（健康检查、登录、分组查询、创建短链）"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/actuator/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "actuator",
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('健康检查返回 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('服务状态 UP', function () {",
              "    pm.expect(body.status).to.eql('UP');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/short-link/admin/v1/user/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "short-link",
            "admin",
            "v1",
            "user",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('登录返回成功', function () {",
              "    pm.response.to.have.status(200);",
              "    const body = pm.response.json();",
              "    pm.expect(body.code).to.eql('0');",
              "    pm.expect(body.data.token).to.not.be.undefined;",
              "});",
              "const body = pm.response.json();",
              "pm.environment.set('token', body.data.token);",
              "pm.environment.set('usernameHeader', pm.environment.get('username'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Query Group",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Token",
            "value": "{{token}}"
          },
          {
            "key": "Username",
            "value": "{{usernameHeader}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/short-link/admin/v1/group",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "short-link",
            "admin",
            "v1",
            "group"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('分组查询成功', function () {",
              "    pm.response.to.have.status(200);",
              "    const body = pm.response.json();",
              "    pm.expect(body.code).to.eql('0');",
              "    pm.expect(body.data.length).to.be.greaterThan(0);",
              "});",
              "const body = pm.response.json();",
              "pm.environment.set('gid', body.data[0].gid);"
            ]
          }
        }
      ]
    },
    {
      "name": "Create ShortLink",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Token",
            "value": "{{token}}"
          },
          {
            "key": "Username",
            "value": "{{usernameHeader}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"domain\": \"nurl.ink:8003\",\n  \"originUrl\": \"https://example.com\",\n  \"gid\": \"{{gid}}\",\n  \"createdType\": 1,\n  \"validDateType\": 0,\n  \"describe\": \"functional-test-{{$timestamp}}\",\n  \"maxAccessCount\": 30\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/short-link/admin/v1/create",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "short-link",
            "admin",
            "v1",
            "create"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('创建短链成功', function () {",
              "    pm.response.to.have.status(200);",
              "    const body = pm.response.json();",
              "    pm.expect(body.code).to.eql('0');",
              "    pm.expect(body.data.fullShortUrl).to.include('http://');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
