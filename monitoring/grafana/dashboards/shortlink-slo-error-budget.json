{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "可用性（30m）",
      "id": 1,
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - (sum(rate(http_server_requests_seconds_count{job=\"shortlink\",status=~\"5..\"}[30m])) / sum(rate(http_server_requests_seconds_count{job=\"shortlink\"}[30m]))))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 99.0 },
              { "color": "green", "value": 99.9 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "错误预算剩余（SLO 99.9）",
      "id": 2,
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (0.001 - (sum(rate(http_server_requests_seconds_count{job=\"shortlink\",status=~\"5..\"}[30m])) / sum(rate(http_server_requests_seconds_count{job=\"shortlink\"}[30m])))) / 0.001"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "P95 达标率（目标 <= 800ms）",
      "id": 3,
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"shortlink\"}[5m])) by (le)) < bool 0.8)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "当前错误率（5m）",
      "id": 4,
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(http_server_requests_seconds_count{job=\"shortlink\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"shortlink\"}[5m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "错误预算燃烧率（5m / 1h）",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(http_server_requests_seconds_count{job=\"shortlink\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"shortlink\"}[5m]))) / 0.001",
          "legendFormat": "burn rate 5m"
        },
        {
          "refId": "B",
          "expr": "(sum(rate(http_server_requests_seconds_count{job=\"shortlink\",status=~\"5..\"}[1h])) / sum(rate(http_server_requests_seconds_count{job=\"shortlink\"}[1h]))) / 0.001",
          "legendFormat": "burn rate 1h"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "延迟目标达标（P95）",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"shortlink\"}[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "refId": "B",
          "expr": "0.8",
          "legendFormat": "SLO target(0.8s)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["shortlink", "slo", "error-budget"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "ShortLink SLO & Error Budget",
  "uid": "shortlink-slo-error-budget",
  "version": 1
}
