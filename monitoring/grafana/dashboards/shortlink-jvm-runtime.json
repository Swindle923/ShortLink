{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "panels": [
    {
      "type": "timeseries",
      "title": "JVM Heap / Non-Heap",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "sum(jvm_memory_used_bytes{job=\"shortlink-aggregation\",area=\"heap\"})", "legendFormat": "heap used" },
        { "refId": "B", "expr": "sum(jvm_memory_used_bytes{job=\"shortlink-aggregation\",area=\"nonheap\"})", "legendFormat": "nonheap used" },
        { "refId": "C", "expr": "sum(jvm_memory_max_bytes{job=\"shortlink-aggregation\",area=\"heap\"})", "legendFormat": "heap max" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "JVM GC 吞吐与停顿",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "sum(rate(jvm_gc_pause_seconds_count{job=\"shortlink-aggregation\"}[1m]))", "legendFormat": "gc count/s" },
        { "refId": "B", "expr": "sum(rate(jvm_gc_pause_seconds_sum{job=\"shortlink-aggregation\"}[1m]))", "legendFormat": "gc pause seconds/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "JVM 线程",
      "id": 3,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "jvm_threads_live_threads{job=\"shortlink-aggregation\"}", "legendFormat": "live" },
        { "refId": "B", "expr": "jvm_threads_peak_threads{job=\"shortlink-aggregation\"}", "legendFormat": "peak" },
        { "refId": "C", "expr": "jvm_threads_daemon_threads{job=\"shortlink-aggregation\"}", "legendFormat": "daemon" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "JVM 类加载",
      "id": 4,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "jvm_classes_loaded_classes{job=\"shortlink-aggregation\"}", "legendFormat": "loaded" },
        { "refId": "B", "expr": "jvm_classes_unloaded_classes_total{job=\"shortlink-aggregation\"}", "legendFormat": "unloaded total" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "进程 CPU",
      "id": 5,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "process_cpu_usage{job=\"shortlink-aggregation\"}", "legendFormat": "process cpu" },
        { "refId": "B", "expr": "system_cpu_usage{job=\"shortlink-aggregation\"}", "legendFormat": "system cpu" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Tomcat 线程池",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "tomcat_threads_busy_threads{job=\"shortlink-aggregation\"}", "legendFormat": "busy" },
        { "refId": "B", "expr": "tomcat_threads_current_threads{job=\"shortlink-aggregation\"}", "legendFormat": "current" },
        { "refId": "C", "expr": "tomcat_threads_config_max_threads{job=\"shortlink-aggregation\"}", "legendFormat": "max" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "应用运行时长",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "process_uptime_seconds{job=\"shortlink-aggregation\"}", "legendFormat": "uptime" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["shortlink", "jvm"],
  "templating": { "list": [] },
  "time": { "from": "now-2h", "to": "now" },
  "timezone": "browser",
  "title": "ShortLink JVM Runtime",
  "uid": "shortlink-jvm-runtime",
  "version": 1
}
