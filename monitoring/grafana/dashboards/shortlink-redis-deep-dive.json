{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "Redis 可用性",
      "id": 1,
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{ "refId": "A", "expr": "redis_up{job=\"redis-exporter\"}" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "连接客户端数",
      "id": 2,
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{ "refId": "A", "expr": "redis_connected_clients{job=\"redis-exporter\"}" }]
    },
    {
      "type": "stat",
      "title": "命中率",
      "id": 3,
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "100 * rate(redis_keyspace_hits_total{job=\"redis-exporter\"}[5m]) / (rate(redis_keyspace_hits_total{job=\"redis-exporter\"}[5m]) + rate(redis_keyspace_misses_total{job=\"redis-exporter\"}[5m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "QPS",
      "id": 4,
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{ "refId": "A", "expr": "rate(redis_commands_processed_total{job=\"redis-exporter\"}[1m])" }],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Redis 内存明细",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "redis_memory_used_bytes{job=\"redis-exporter\"}", "legendFormat": "used" },
        { "refId": "B", "expr": "redis_memory_max_bytes{job=\"redis-exporter\"}", "legendFormat": "max" },
        { "refId": "C", "expr": "redis_memory_used_rss_bytes{job=\"redis-exporter\"}", "legendFormat": "rss" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "网络 IO",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "rate(redis_net_input_bytes_total{job=\"redis-exporter\"}[1m])", "legendFormat": "in bytes/s" },
        { "refId": "B", "expr": "rate(redis_net_output_bytes_total{job=\"redis-exporter\"}[1m])", "legendFormat": "out bytes/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "过期与淘汰",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "rate(redis_expired_keys_total{job=\"redis-exporter\"}[1m])", "legendFormat": "expired/s" },
        { "refId": "B", "expr": "rate(redis_evicted_keys_total{job=\"redis-exporter\"}[1m])", "legendFormat": "evicted/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "连接拒绝与慢日志",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "increase(redis_rejected_connections_total{job=\"redis-exporter\"}[5m])", "legendFormat": "rejected conn/5m" },
        { "refId": "B", "expr": "redis_slowlog_length{job=\"redis-exporter\"}", "legendFormat": "slowlog length" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["shortlink", "redis"],
  "templating": { "list": [] },
  "time": { "from": "now-2h", "to": "now" },
  "timezone": "browser",
  "title": "ShortLink Redis Deep Dive",
  "uid": "shortlink-redis-deep-dive",
  "version": 1
}
